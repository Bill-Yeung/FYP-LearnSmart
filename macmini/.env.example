# Mac Mini LLM Gateway Environment Variables
# Copy this file to .env (local) or .env.prod (production)

# Connection Settings
BIND_HOST=10.50.0.1
PORT=8001
BASE_URL=http://127.0.0.1:11434/

# LLM Settings
TIMEOUT=900
MAX_CHAT_CONCURRENCY=1
MAX_EMBED_CONCURRENCY=32
MAX_CLIP_CONCURRENCY=2
MAX_WHISPER_CONCURRENCY=1
MAX_FLUX_CONCURRENCY=1
SDXL_MODEL=stabilityai/sd-turbo
FLUX_MODEL=black-forest-labs/FLUX.1-schnell
ALLOWED_MODELS=["gpt-oss:20b","qwen2.5:32b","qwen2.5:72b","llama3.1:70b","bge-m3:latest","nomic-embed-text:latest"]

# HuggingFace — https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token

# Model cache directory (absolute path on the Mac Mini)
MODEL_CACHE_DIR=/Users/ituser/model-cache
