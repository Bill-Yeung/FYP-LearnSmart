# Local Development Environment
# Copy this file to .env and fill in your values

#### Database Settings ###

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=learning_platform

# Neo4j
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=learning_platform
QDRANT_DIMENSIONS=1024

#### LLM Settings ###

# DeepSeek API — https://platform.deepseek.com
DEEPSEEK_API_KEY="your_deepseek_api_key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MAX_REQUESTS=10
DEEPSEEK_MODELS=[{"name":"deepseek-chat","key":"deepseek-chat","context_window":131072,"max_output":8192},{"name":"deepseek-reasoner","key":"deepseek-reasoner","context_window":131072,"max_output":65536,"timeout":600}]
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MAX_REQUESTS=10
OPENROUTER_MODELS=[{"name":"deepseek/deepseek-r1-0528:free","key":"deepseek-r1-free","context_window":163800,"max_output":163800}]
OPENROUTER_DEFAULT_MODEL=deepseek-r1-free

# Qwen API — https://dashscope.aliyuncs.com
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MAX_REQUESTS=10
QWEN_MODELS=[{"name":"qwen-long","key":"qwen-long","context_window":10000000,"max_output":32768}]
QWEN_DEFAULT_MODEL=qwen-long

# Mac Mini (LLM Gateway) — optional, leave blank if not using
MACMINI_BASE_URL="http://10.50.0.1:8001"
MACMINI_MAX_REQUESTS=1
MACMINI_MODELS=[{"name":"qwen2.5:32b","key":"qwen-32b","context_window":32768,"max_output":16384,"timeout":300}]
MACMINI_DEFAULT_MODEL=qwen-32b
MACMINI_EMBED_MODELS=[{"name":"bge-m3:latest","key":"bge-m3","dimensions":1024,"max_tokens":8192},{"name":"nomic-embed-text:latest","key":"nomic","dimensions":768,"max_tokens":8192}]
MACMINI_DEFAULT_EMBED_MODEL=bge-m3

# Ollama (Local) — https://ollama.com
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MAX_REQUESTS=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_GPU=999 # 0 = CPU only, 999 = all GPUs
OLLAMA_MODELS=[{"name":"qwen2.5:7b","key":"qwen-7b","context_window":32768,"max_output":8192}]
OLLAMA_DEFAULT_MODEL=qwen-7b
OLLAMA_EMBED_MODELS=[{"name":"mxbai-embed-large","key":"mxbai-embed-large","dimensions":1024,"max_tokens":512}]
OLLAMA_DEFAULT_EMBED_MODEL=mxbai-embed-large

# Context Window & Chunking
MAX_CONTEXT_USAGE=0.8
CHUNK_OVERLAP_TOKENS=500

#### Connection Settings ###

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# JWT Authentication — generate with: openssl rand -hex 32
SECRET_KEY=your_jwt_secret_key_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth — create apps at console.cloud.google.com and github.com/settings/developers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:5173/api/auth/github/callback

### Service Settings ###

# File Storage
UPLOAD_DIR=/app/uploads

# Image Generation (FLUX via Mac Mini) — optional
FLUX_HOST=10.50.0.1
FLUX_PORT=8100
FLUX_MODEL=FLUX.1-schnell
FLUX_DEVICE=cpu

# Email Configuration — use your SMTP provider credentials
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=Learning Platform
SMTP_HOST=host.docker.internal
SMTP_PORT=25
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_RELAY_HOSTNAME=learning-platform.local
SMTP_RELAY_PORT=465
SMTP_RELAY_SERVER=smtp.gmail.com
