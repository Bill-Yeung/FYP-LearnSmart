# Web App Environment Variables
# Copy this file to .env (local dev) or .env.production (production build)

# API endpoint for the backend
VITE_API_URL=http://localhost:8000

# Cloudflare Access service token — required in production to bypass Cloudflare Access OTP
# Create at: https://one.dash.cloudflare.com → Access → Service Tokens
VITE_CF_ACCESS_CLIENT_ID=your_cf_access_client_id
VITE_CF_ACCESS_CLIENT_SECRET=your_cf_access_client_secret
