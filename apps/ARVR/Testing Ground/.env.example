# AR/VR Testing Ground Environment Variables
# Copy this file to .env and fill in your values

# Cloudflare Access service token — bypasses Cloudflare Access OTP for the backend
# Create at: https://one.dash.cloudflare.com → Access → Service Tokens
CF_ACCESS_CLIENT_ID=your_cf_access_client_id
CF_ACCESS_CLIENT_SECRET=your_cf_access_client_secret
